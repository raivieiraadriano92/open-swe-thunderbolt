FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends git curl \
    && rm -rf /var/lib/apt/lists/*
RUN pip install --no-cache-dir uv

WORKDIR /app
# hatchling validates the readme file exists during metadata parsing, so it
# has to be present alongside pyproject.toml + uv.lock in the deps layer.
COPY pyproject.toml uv.lock README.md ./
RUN uv sync --all-extras --frozen --no-dev

COPY . .

EXPOSE 2024
CMD ["uv", "run", "langgraph", "dev", "--host", "0.0.0.0", "--port", "2024", "--no-browser", "--no-reload"]
