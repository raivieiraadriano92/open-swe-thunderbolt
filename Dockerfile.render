FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends git curl \
    && rm -rf /var/lib/apt/lists/*
RUN pip install --no-cache-dir uv

WORKDIR /app
# hatchling validates the readme file exists during metadata parsing, so it
# has to be present alongside pyproject.toml + uv.lock in the deps layer.
COPY pyproject.toml uv.lock README.md ./
RUN uv sync --all-extras --frozen --no-dev

COPY . .

EXPOSE 2024
# THU-696 patch #9: switch from `langgraph dev` (pickle-file dev-mode) to
# langgraph_api.cli with --runtime-edition postgres. This is the same server
# `langgraph up` uses in docker-compose deployments, but invoked directly so
# we can run in a single Render container. Reads DATABASE_URI + REDIS_URI
# from env; the postgres edition hard-requires both.
CMD ["uv", "run", "python", "-m", "langgraph_api.cli", "--host", "0.0.0.0", "--port", "2024", "--runtime-edition", "postgres", "--no-reload"]
